msgid "Control Panel Connection"
msgstr "חיבור לוח הבקרה"

#. Description of the plugin
msgid "This utility plugin is used by our control panel for various tasks, such as authenticating you as an admin when logging in through the WP Admin button, or helping you return to the control panel."
msgstr "תוסף שירות זה משמש את לוח הבקרה שלנו למשימות שונות, כגון אימות זהותך כמנהל בעת כניסה דרך כפתור WP Admin, או לסייע לך לחזור ללוח הבקרה."

msgid "Settings saved."
msgstr "ההגדרות נשמרו."

msgid "An error occurred while saving settings."
msgstr "אירעה שגיאה בעת שמירת ההגדרות."

msgid "An unexpected error occurred. Please try again."
msgstr "אירעה שגיאה בלתי צפויה. אנא נסה שוב."

msgid "You do not have permission to manage plugin settings."
msgstr "אין לך הרשאה לנהל את הגדרות התוסף."

msgid "Unauthorized"
msgstr "לא מורשה"

msgid "Settings"
msgstr "הגדרות"

msgid "Show Control Panel Bar"
msgstr "הצג את סרגל לוח הבקרה"

msgid "Display the Control Panel bar at the top of the page"
msgstr "הצג את סרגל לוח הבקרה בראש הדף"

msgid "Show Link In Admin Menu"
msgstr "הצג קישור בתפריט הניהול"

msgid "Display a link to the Control Panel in the WordPress admin menu"
msgstr "הצג קישור ללוח הבקרה בתפריט הניהול של WordPress"

msgid "Show Link In Admin Bar"
msgstr "הצג קישור בסרגל הניהול"

msgid "Display a link to the Control Panel in the WordPress admin bar"
msgstr "הצג קישור ללוח הבקרה בסרגל הניהול של WordPress"

msgid "Back to Control Panel"
msgstr "חזרה ללוח הבקרה"

msgid "Upgrade Now"
msgstr "שדרג עכשיו"

msgid "Hide this bar"
msgstr "הסתר סרגל זה"

#, php-format
msgid "Version %s"
msgstr "גרסה %s"

msgid "By"
msgstr "מאת"
