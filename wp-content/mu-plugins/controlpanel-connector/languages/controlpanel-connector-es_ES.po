msgid "Control Panel Connection"
msgstr "Conexión al Panel de Control"

#. Description of the plugin
msgid "This utility plugin is used by our control panel for various tasks, such as authenticating you as an admin when logging in through the WP Admin button, or helping you return to the control panel."
msgstr "Este plugin utilitario es utilizado por nuestro panel de control para diversas tareas, como autenticarte como administrador al iniciar sesión mediante el botón WP Admin, o ayudarte a regresar al panel de control."

msgid "Settings saved."
msgstr "Configuración guardada."

msgid "An error occurred while saving settings."
msgstr "Se produjo un error al guardar la configuración."

msgid "An unexpected error occurred. Please try again."
msgstr "Se produjo un error inesperado. Por favor, inténtelo de nuevo."

msgid "You do not have permission to manage plugin settings."
msgstr "No tiene permiso para gestionar la configuración del plugin."

msgid "Unauthorized"
msgstr "No autorizado"

msgid "Settings"
msgstr "Configuración"

msgid "Show Control Panel Bar"
msgstr "Mostrar barra del panel de control"

msgid "Display the Control Panel bar at the top of the page"
msgstr "Mostrar la barra del panel de control en la parte superior de la página"

msgid "Show Link In Admin Menu"
msgstr "Mostrar enlace en el menú de administración"

msgid "Display a link to the Control Panel in the WordPress admin menu"
msgstr "Mostrar un enlace al panel de control en el menú de administración de WordPress"

msgid "Show Link In Admin Bar"
msgstr "Mostrar enlace en la barra de administración"

msgid "Display a link to the Control Panel in the WordPress admin bar"
msgstr "Mostrar un enlace al panel de control en la barra de administración de WordPress"

msgid "Back to Control Panel"
msgstr "Volver al panel de control"

msgid "Upgrade Now"
msgstr "Actualizar ahora"

msgid "Hide this bar"
msgstr "Ocultar esta barra"

