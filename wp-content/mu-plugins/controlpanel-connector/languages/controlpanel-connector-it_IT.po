msgid "Control Panel Connection"
msgstr "Connessione al pannello di controllo"

#. Description of the plugin
msgid "This utility plugin is used by our control panel for various tasks, such as authenticating you as an admin when logging in through the WP Admin button, or helping you return to the control panel."
msgstr "Questo plugin di utilità viene utilizzato dal nostro pannello di controllo per varie attività, come autenticarti come amministratore durante l'accesso tramite il pulsante WP Admin, o aiutarti a tornare al pannello di controllo."

msgid "Settings saved."
msgstr "Impostazioni salvate."

msgid "An error occurred while saving settings."
msgstr "Si è verificato un errore durante il salvataggio delle impostazioni."

msgid "An unexpected error occurred. Please try again."
msgstr "Si è verificato un errore imprevisto. Riprova."

msgid "You do not have permission to manage plugin settings."
msgstr "Non hai il permesso di gestire le impostazioni del plugin."

msgid "Unauthorized"
msgstr "Non autorizzato"

msgid "Settings"
msgstr "Impostazioni"

msgid "Show Control Panel Bar"
msgstr "Mostra la barra del pannello di controllo"

msgid "Display the Control Panel bar at the top of the page"
msgstr "Visualizza la barra del pannello di controllo nella parte superiore della pagina"

msgid "Show Link In Admin Menu"
msgstr "Mostra il link nel menu di amministrazione"

msgid "Display a link to the Control Panel in the WordPress admin menu"
msgstr "Visualizza un link al pannello di controllo nel menu di amministrazione di WordPress"

msgid "Show Link In Admin Bar"
msgstr "Mostra il link nella barra di amministrazione"

msgid "Display a link to the Control Panel in the WordPress admin bar"
msgstr "Visualizza un link al pannello di controllo nella barra di amministrazione di WordPress"

msgid "Back to Control Panel"
msgstr "Torna al pannello di controllo"

msgid "Upgrade Now"
msgstr "Aggiorna ora"

msgid "Hide this bar"
msgstr "Nascondi questa barra"

#, php-format
msgid "Version %s"
msgstr "Versione %s"

msgid "By"
msgstr "Di"
