{
    "version": 3,
    "settings": {
        "appearanceTools": true,
        "useRootPaddingAwareAlignments": true,
        "layout": {
            "contentSize": "930px",
            "wideSize": "1400px"
        },
        "spacing": {
            "blockGap": true,
            "margin": true,
            "padding": true,
            "units": ["px", "em", "rem", "vh", "vw"]
        }
    },
    "styles": {
        "blocks": {
            "core/image": {
                "spacing": {
                    "margin": {
                        "left": "auto",
                        "right": "auto"
                    }
                }
            },
            "core/heading": {
                "typography": {
                    "lineHeight": "1.3"
                }
            },
            "core/list": {
                "spacing": {
                    "blockGap": "0.5em"
                }
            },
            "core/post-terms": {
                "typography": {
                    "fontSize": "0.75rem",                    
                    "fontWeight": "700",
                    "letterSpacing": "0.05em"
                }
            },
            "core/table": {
                "border": {
                    "color": "rgba(0, 0, 0, 0.1)",
                    "style": "solid",
                    "width": "1px"
                },
                "typography": {
                    "fontSize": "0.9rem"
                },
                "elements": {
                    "caption": {
                        "typography": { "fontSize": "0.8rem", "fontStyle": "italic" }
                    }
                }
            },
            "core/pullquote": {
                "border": {
                    "top": { "width": "4px", "style": "solid", "color": "currentColor" },
                    "bottom": { "width": "4px", "style": "solid", "color": "currentColor" }
                },
                "typography": {
                    "fontSize": "1.5rem",
                    "lineHeight": "1.2",
                    "fontStyle": "italic"
                },
                "spacing": {
                    "margin": { "top": "2em", "bottom": "2em" },
                    "padding": { "top": "1em", "bottom": "1em" }
                }
            }
        },
        "elements": {
            "link": {
                "typography": {
                    "textDecoration": "none"
                }
            },
            "button": {
                "border": {
                    "radius": "0",
                    "width": "1px",
                    "style": "solid",
                    "color": "rgba(0, 0, 0, 0.3)"
                },
                "typography": {
                    "fontSize": "14px",
                    "lineHeight": "1",
                    "fontWeight": "600"
                },
                "spacing": {
                    "padding": {
                        "top": "9px",
                        "bottom": "9px",
                        "left": "15px",
                        "right": "15px"
                    }
                }
            }
        }
    }
}